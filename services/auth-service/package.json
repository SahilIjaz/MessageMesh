{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Authentication service for MessageMesh",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "migrate": "knex migrate:latest --cwd .",
    "migrate:down": "knex migrate:rollback --cwd .",
    "migrate:fresh": "knex migrate:rollback --all --cwd . && knex migrate:latest --cwd ."
  },
  "dependencies": {
    "express": "^4.18.2",
    "@messagemesh/middleware": "1.0.0",
    "@messagemesh/utils": "1.0.0",
    "@messagemesh/events": "1.0.0",
    "pg": "^8.10.0",
    "knex": "^2.5.1",
    "dotenv": "^16.0.3",
    "joi": "^17.9.0"
  },
  "devDependencies": {
    "nodemon": "^2.0.22",
    "jest": "^29.5.0",
    "supertest": "^6.3.3"
  }
}
