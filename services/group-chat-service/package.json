{
  "name": "group-chat-service",
  "version": "1.0.0",
  "description": "MessageMesh Group Chat Service",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "migrate": "knex migrate:latest",
    "migrate:down": "knex migrate:rollback",
    "migrate:fresh": "knex migrate:rollback --all && knex migrate:latest",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@messagemesh/middleware": "*",
    "@messagemesh/utils": "*",
    "@messagemesh/events": "*",
    "express": "^4.18.2",
    "pg": "^8.10.0",
    "knex": "^3.0.0",
    "joi": "^17.10.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.5.0"
  }
}
