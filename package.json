{
  "name": "messagemesh",
  "version": "1.0.0",
  "description": "Real-time chat microservices application",
  "private": true,
  "workspaces": [
    "services/*",
    "shared/*"
  ],
  "scripts": {
    "lint": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write .",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "docker:build": "docker-compose -f infra/docker-compose.yml build",
    "docker:up": "docker-compose -f infra/docker-compose.yml up",
    "docker:down": "docker-compose -f infra/docker-compose.yml down",
    "docker:logs": "docker-compose -f infra/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.40.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.27.5",
    "jest": "^29.5.0",
    "prettier": "^2.8.8",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
